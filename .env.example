APP_NAME=CathyChang AI
APP_BUILD_ID=2026-04-21-route-budget-v2
APP_PASSWORD=
APP_USERS=
SESSION_SECRET=
SESSION_TTL_SEC=28800
MEMORY_ROOT=./data/memory
CORS_ALLOW_ORIGINS=http://localhost:3000
DEBUG=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=12
RATE_LIMIT_WINDOW_SEC=60
AGENT_PROVIDER_ORDER=cerebras,groq,mistral,gemini,openrouter,cloudflare,fireworks,aws,nvidia
MAX_OUTPUT_TOKENS=4096
REQUEST_TIMEOUT_SEC=120
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# ── AI Code-Review Hook (Claude Code partner) ────────────────────────────────
# The hook auto-selects the first key set below (priority: Gemini → Claude → OpenAI).
# GEMINI_API_KEY is already used by this project — no new account needed.
#
# Provider    Model                  Cost/review   Account needed
# ---------   --------------------   -----------   ----------------------------
# Gemini      gemini-2.0-flash-lite  ~$0.000007    Already in this project ✓
# Anthropic   claude-haiku-4-5       ~$0.0001      platform.anthropic.com
# OpenAI      gpt-4o-mini            ~$0.00015     platform.openai.com (separate from ChatGPT)
#
# Optional overrides:
CODEX_REVIEW_MODEL=        # leave blank to use provider default
CODEX_REVIEW_MAX_LINES=300
OPENAI_API_KEY=            # only needed if not using Gemini or Anthropic
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/minimax-m2p7
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_OCR_MODEL=gemini-2.5-flash-lite
GEMINI_ETL_MODEL=gemini-2.5-flash-lite
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
ANTHROPIC_API_KEY=
CREDIT_REPORT_MODEL=claude-sonnet-4-6
CR_SECTION_MAX_TOKENS=8192
CR_MAX_CONCURRENT_GENERATIONS=2
CREDIT_REPORTS_ROOT=/tmp/credit_reports
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_EMAIL=
ADMIN_PASSWORD=

ENVIRONMENT=development
AUTO_CREATE_TABLES=true
