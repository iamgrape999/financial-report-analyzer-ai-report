# Financial Report Analyzer — local development example
ENVIRONMENT=development
DEBUG=false

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/credit_report.db
# Local dev convenience only. Production should run Alembic migrations instead.
AUTO_CREATE_TABLES=true

# CORS: use explicit frontend origins in production, separated by commas.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

# Gemini section generation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Optional override for metadata/client model ID. Defaults to GEMINI_MODEL.
GENERATION_MODEL_ID=gemini-2.5-flash
CR_SECTION_MAX_TOKENS=8192
CR_MAX_CONCURRENT_GENERATIONS=2
DAILY_TOKEN_LIMIT=4000000
CREDIT_REPORTS_ROOT=./data/credit_reports
CREDIT_REPORT_MAX_UPLOAD_MB=50

# Auth / admin bootstrap
# Use a strong random value in every shared or production environment.
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_EMAIL=
ADMIN_PASSWORD=
