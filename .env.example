APP_NAME=CathyChang AI
APP_BUILD_ID=2026-04-21-route-budget-v2
APP_PASSWORD=
APP_USERS=
SESSION_SECRET=
SESSION_TTL_SEC=28800
MEMORY_ROOT=./data/memory
CORS_ALLOW_ORIGINS=http://localhost:3000
DEBUG=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=12
RATE_LIMIT_WINDOW_SEC=60
AGENT_PROVIDER_ORDER=cerebras,groq,mistral,gemini,openrouter,cloudflare,fireworks,aws,nvidia
MAX_OUTPUT_TOKENS=4096
REQUEST_TIMEOUT_SEC=120
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# ── AI Code-Review Hook (Claude Code partner) ────────────────────────────────
# Fires automatically on every Edit/Write to production Python files.
# Reviewer role: stronger Gemini model audits Claude Sonnet 4.6's edits.
#
# Set in Render environment — leave GEMINI_REVIEWER_API_KEY blank to disable.
#
#   GEMINI_REVIEWER_API_KEY  Gemini API key (separate from app's GEMINI_API_KEY)
#   GEMINI_REVIEWER_MODEL    model ID — swap anytime in Render env, no redeploy
#
# Model options (cost per review ≈ 3 000 input + 150 output tokens):
#   gemini-3.5-flash          ~$0.006   ← default · best for coding/agentic tasks
#   gemini-3.1-pro-preview    ~$0.008   ← SOTA reasoning, multimodal
#   gemini-3-flash-preview    ~$0.002   ← frontier intelligence + grounding
#   gemini-3.1-flash-lite     ~$0.001   ← highest volume, lowest cost
#   gemini-2.5-pro            ~$0.004   ← previous generation pro
#   gemini-2.5-flash          ~$0.0005  ← previous generation flash
#
# If GEMINI_REVIEWER_API_KEY is not set → silent no-op (no review, no error).
GEMINI_REVIEWER_API_KEY=
GEMINI_REVIEWER_MODEL=gemini-3.5-flash
CODEX_REVIEW_MAX_LINES=300
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/minimax-m2p7
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_OCR_MODEL=gemini-2.5-flash-lite
GEMINI_ETL_MODEL=gemini-2.5-flash-lite
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
CR_SECTION_MAX_TOKENS=8192
CR_MAX_CONCURRENT_GENERATIONS=2
CREDIT_REPORTS_ROOT=/tmp/credit_reports
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_EMAIL=
ADMIN_PASSWORD=

ENVIRONMENT=development
AUTO_CREATE_TABLES=true
